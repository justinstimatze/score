{
  "name": "score-miro-app",
  "version": "0.1.0",
  "description": "Arc linter + planner — Miro panel sidebar",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src",
    "format": "biome format src --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/node": "^25.3.3",
    "typescript": "^5.5.0",
    "vite": "^6.4.2",
    "vitest": "^4.0.18"
  }
}
